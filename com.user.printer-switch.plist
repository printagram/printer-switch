<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.printer-switch</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/usr/local/bin/printer_switch.sh</string>
    </array>

    <key>StartInterval</key>
    <integer>180</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/printer_switch.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/printer_switch.error.log</string>
</dict>
</plist>
